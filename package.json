{
  "name": "deployinfra",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "example": "pnpm --filter deployinfra-example run deploy --",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "test:e2e:full": "DEPLOYINFRA_E2E_PROFILE=full vitest run --config e2e/vitest.config.ts",
    "test:e2e:source": "vitest run --config e2e/vitest.config.ts e2e/source-contract.e2e.test.ts",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@deployinfra/aws": "workspace:*",
    "@deployinfra/cloudflare": "workspace:*",
    "@deployinfra/firebase": "workspace:*",
    "@deployinfra/sdk": "workspace:*",
    "@deployinfra/netlify": "workspace:*",
    "@deployinfra/vercel": "workspace:*",
    "@types/node": "^26.1.1",
    "fflate": "^0.8.3",
    "tsx": "^4.20.5",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
