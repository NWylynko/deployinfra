{
  "name": "@deployinfra/sdk",
  "version": "0.0.0",
  "description": "Unified deployment SDK — create a deployer once, deploy to any provider.",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NWylynko/deployinfra.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/NWylynko/deployinfra#readme",
  "bugs": {
    "url": "https://github.com/NWylynko/deployinfra/issues"
  },
  "keywords": [
    "deploy",
    "deployment",
    "hosting",
    "sdk",
    "vercel",
    "netlify",
    "cloudflare",
    "railway"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "require": "./dist/internal.js",
      "default": "./dist/internal.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "msw": "^2.15.0",
    "tsdown": "^0.22.9",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "fflate": "^0.8.3"
  }
}
