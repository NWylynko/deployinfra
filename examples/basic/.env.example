# Pick one: vercel, netlify, cloudflare
DEPLOY_PROVIDER=vercel

# Optional deployment name for any provider. If omitted, DeployInfra generates one.
DEPLOY_NAME=

# Vercel
VERCEL_TOKEN=
VERCEL_TEAM_ID=
# Optional fallback for deploy({ name }) when DEPLOY_NAME is unset.
VERCEL_PROJECT_NAME=deployinfra-example
# Optional per-deploy target: production | preview | staging | development
VERCEL_TARGET=

# Netlify
NETLIFY_TOKEN=
# Optional: pass to deploy({ siteId }) for an existing site.
NETLIFY_SITE_ID=
# Optional fallback for deploy({ name }) when DEPLOY_NAME is unset.
NETLIFY_SITE_NAME=deployinfra-example

# Cloudflare Pages
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional fallback for deploy({ name }) when DEPLOY_NAME is unset.
CLOUDFLARE_PROJECT_NAME=deployinfra-example
CLOUDFLARE_BRANCH=main
